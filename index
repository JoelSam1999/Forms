<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <meta name="theme-color" content="#007bff">

  <title>Chapter Quiz</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
    }

    .header {
      text-align: center;
      color: white;
      margin-bottom: 30px;
    }

    .header h2 {
      font-size: 28px;
      margin-bottom: 10px;
    }

    .card {
      background: white;
      padding: 20px;
      margin-bottom: 15px;
      border-radius: 10px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .card h3 {
      color: #333;
      margin-bottom: 15px;
      font-size: 18px;
    }

    .card p {
      color: #666;
      margin: 8px 0;
      font-size: 15px;
    }

    .quiz-card {
      background: white;
      padding: 15px;
      margin-bottom: 15px;
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .quiz-card p {
      color: #333;
      margin: 5px 0;
    }

    label {
      display: block;
      margin: 8px 0;
      cursor: pointer;
      color: #555;
    }

    input[type="radio"] {
      margin-right: 8px;
      cursor: pointer;
    }

    button {
      padding: 12px 24px;
      background: #007bff;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 16px;
      margin-top: 15px;
      transition: background 0.3s;
    }

    button:hover {
      background: #0056b3;
    }

    button:active {
      background: #003d82;
    }

    .correct { 
      color: #28a745; 
      font-weight: bold;
    }

    .wrong { 
      color: #dc3545; 
      font-weight: bold;
    }

    /* Dashboard Styles */
    .dashboard {
      display: none;
    }

    .dashboard.active {
      display: block;
    }

    .dashboard-container {
      background: white;
      border-radius: 15px;
      padding: 30px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.3);
    }

    .dashboard h1 {
      text-align: center;
      color: #333;
      margin-bottom: 10px;
      font-size: 32px;
    }

    .emoji {
      text-align: center;
      font-size: 60px;
      margin-bottom: 20px;
    }

    .overall-score {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 30px;
      border-radius: 12px;
      text-align: center;
      margin-bottom: 30px;
    }

    .overall-score h2 {
      font-size: 24px;
      margin-bottom: 10px;
    }

    .score-number {
      font-size: 48px;
      font-weight: bold;
      margin: 10px 0;
    }

    .score-percentage {
      font-size: 20px;
      opacity: 0.9;
    }

    .chapter-results {
      margin-bottom: 30px;
    }

    .chapter-results h3 {
      color: #333;
      margin-bottom: 15px;
      font-size: 20px;
      border-bottom: 2px solid #667eea;
      padding-bottom: 10px;
    }

    .chapter-result-item {
      background: #f8f9fa;
      padding: 15px;
      margin-bottom: 12px;
      border-radius: 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-left: 4px solid #667eea;
    }

    .chapter-result-item.excellent {
      border-left-color: #28a745;
    }

    .chapter-result-item.good {
      border-left-color: #ffc107;
    }

    .chapter-result-item.poor {
      border-left-color: #dc3545;
    }

    .chapter-name {
      color: #333;
      font-weight: bold;
      font-size: 16px;
    }

    .chapter-score {
      background: white;
      padding: 8px 16px;
      border-radius: 6px;
      color: #667eea;
      font-weight: bold;
      font-size: 18px;
    }

    .progress-bar {
      background: #e9ecef;
      height: 10px;
      border-radius: 5px;
      margin-top: 10px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
      transition: width 0.3s;
    }

    .performance-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 15px;
      margin-bottom: 30px;
    }

    .stat-box {
      background: #f8f9fa;
      padding: 20px;
      border-radius: 8px;
      text-align: center;
      border: 2px solid #e9ecef;
    }

    .stat-box h4 {
      color: #666;
      font-size: 14px;
      margin-bottom: 10px;
      text-transform: uppercase;
    }

    .stat-value {
      font-size: 28px;
      font-weight: bold;
      color: #667eea;
    }

    .action-buttons {
      display: flex;
      gap: 15px;
      margin-top: 30px;
      flex-wrap: wrap;
    }

    .btn-primary {
      flex: 1;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-width: 150px;
    }

    .btn-primary:hover {
      opacity: 0.9;
    }

    .btn-secondary {
      flex: 1;
      background: #6c757d;
      min-width: 150px;
    }

    .btn-secondary:hover {
      background: #5a6268;
    }

    .feedback-section {
      background: #e7f3ff;
      border-left: 4px solid #2196F3;
      padding: 15px;
      border-radius: 6px;
      margin-top: 20px;
    }

    .feedback-section h4 {
      color: #2196F3;
      margin-bottom: 10px;
    }

    .feedback-section p {
      color: #0066cc;
      line-height: 1.6;
    }

    @media (max-width: 600px) {
      .performance-stats {
        grid-template-columns: 1fr;
      }

      .action-buttons {
        flex-direction: column;
      }

      .btn-primary, .btn-secondary {
        min-width: auto;
        flex: none;
        width: 100%;
      }

      .overall-score h2 {
        font-size: 18px;
      }

      .score-number {
        font-size: 36px;
      }
    }
  </style>
</head>

<body>

<div class="container">
  <!-- Quiz Section -->
  <div id="quiz-section">
    <div class="header">
      <h2>📘 Chapter-Based Quiz</h2>
    </div>

    <div id="quiz"></div>
    <div id="result"></div>
  </div>

  <!-- Dashboard Section -->
  <div class="dashboard" id="dashboard-section">
    <div class="dashboard-container">
      <div class="emoji">🎉</div>
      <h1>Quiz Completed!</h1>

      <div class="overall-score">
        <h2>Your Overall Performance</h2>
        <div class="score-number" id="overall-score">0/0</div>
        <div class="score-percentage" id="overall-percentage">0%</div>
      </div>

      <!-- Performance Stats -->
      <div class="performance-stats">
        <div class="stat-box">
          <h4>Total Chapters</h4>
          <div class="stat-value" id="stat-chapters">0</div>
        </div>
        <div class="stat-box">
          <h4>Perfect Scores</h4>
          <div class="stat-value" id="stat-perfect">0</div>
        </div>
        <div class="stat-box">
          <h4>Average Score</h4>
          <div class="stat-value" id="stat-average">0%</div>
        </div>
      </div>

      <!-- Chapter Results -->
      <div class="chapter-results">
        <h3>📊 Chapter-Wise Results</h3>
        <div id="chapter-results-list"></div>
      </div>

      <!-- Feedback -->
      <div class="feedback-section">
        <h4>💡 Performance Feedback</h4>
        <p id="feedback-text"></p>
      </div>

      <!-- Action Buttons -->
      <div class="action-buttons">
        <button class="btn-primary" onclick="restartQuiz()">🔄 Retake Quiz</button>
        <button class="btn-secondary" onclick="downloadResults()">📥 Download Results</button>
      </div>
    </div>
  </div>
</div>

<script>
  let quizData = {};
  let sectionNames = [];
  let currentSection = 0;
  let chapterScores = {}; // Store scores for each chapter

  window.addEventListener('load', function() {
    google.script.run
      .withSuccessHandler(function(data) {
        sectionNames = Object.keys(data).sort();
        quizData = data;
        loadSection();
      })
      .withFailureHandler(function(error) {
        document.getElementById("quiz").innerHTML = 
          '<p style="color: red;">Error loading quiz data. Please refresh.</p>';
        console.error("Error:", error);
      })
      .getQuizData();
  });

  // Load chapter
  function loadSection() {
    const section = sectionNames[currentSection];
    const questions = quizData[section];

    let html = `<h3>${section}</h3>`;

    questions.forEach((q, i) => {
      html += `<div class="quiz-card">
        <p><b>${i + 1}. ${q.question}</b></p>`;

      q.options.forEach((opt, j) => {
        html += `
          <label>
            <input type="radio" name="q${i}" value="${j}">
            ${opt}
          </label>`;
      });

      html += `<div id="feedback${i}"></div>`;
      html += `</div>`;
    });

    html += `<button onclick="submitSection()">Submit Chapter</button>`;

    document.getElementById("quiz").innerHTML = html;
    document.getElementById("result").innerHTML = "";
  }

  // Submit answers
  function submitSection() {
    const section = sectionNames[currentSection];
    const questions = quizData[section];

    let correct = 0;

    questions.forEach((q, i) => {
      const selected = document.querySelector(`input[name="q${i}"]:checked`);
      const feedback = document.getElementById(`feedback${i}`);

      if (selected) {
        let selectedText = q.options[selected.value];

        if (selectedText === q.correctAnswer) {
          correct++;
          feedback.innerHTML = "✅ Correct";
          feedback.className = "correct";
        } else {
          feedback.innerHTML = `❌ Wrong (Correct: ${q.correctAnswer})`;
          feedback.className = "wrong";
        }
      } else {
        feedback.innerHTML = "⚠️ Please select an answer";
        feedback.style.color = "#ff9800";
      }
    });

    // Store score for this chapter
    chapterScores[section] = {
      correct: correct,
      total: questions.length
    };

    let total = questions.length;
    let percent = ((correct / total) * 100).toFixed(1);

    let html = `
      <h3>📊 ${section} Completed</h3>
      <p><b>Score: ${correct} / ${total} (${percent}%)</b></p>
    `;

    if (currentSection < sectionNames.length - 1) {
      html += `<button onclick="nextSection()">Next Chapter →</button>`;
    } else {
      html += `<button onclick="showDashboard()">View Dashboard</button>`;
    }

    document.getElementById("result").innerHTML = html;
  }

  // Next chapter
  function nextSection() {
    currentSection++;
    if (currentSection < sectionNames.length) {
      loadSection();
    }
  }

  // Show Dashboard
  function showDashboard() {
    // Calculate overall stats
    let totalCorrect = 0;
    let totalQuestions = 0;
    let perfectScores = 0;

    Object.keys(chapterScores).forEach(chapter => {
      const score = chapterScores[chapter];
      totalCorrect += score.correct;
      totalQuestions += score.total;
      if (score.correct === score.total) {
        perfectScores++;
      }
    });

    const overallPercent = ((totalCorrect / totalQuestions) * 100).toFixed(1);
    const averagePercent = (overallPercent / sectionNames.length).toFixed(1);

    // Update overall score
    document.getElementById("overall-score").textContent = `${totalCorrect}/${totalQuestions}`;
    document.getElementById("overall-percentage").textContent = `${overallPercent}%`;

    // Update stats
    document.getElementById("stat-chapters").textContent = sectionNames.length;
    document.getElementById("stat-perfect").textContent = perfectScores;
    document.getElementById("stat-average").textContent = `${averagePercent}%`;

    // Generate chapter results
    let chapterResultsHtml = "";
    sectionNames.forEach(chapter => {
      const score = chapterScores[chapter];
      const percent = ((score.correct / score.total) * 100).toFixed(1);
      let className = "";
      
      if (percent >= 80) className = "excellent";
      else if (percent >= 60) className = "good";
      else className = "poor";

      chapterResultsHtml += `
        <div class="chapter-result-item ${className}">
          <div class="chapter-name">${chapter}</div>
          <div>
            <div class="progress-bar">
              <div class="progress-fill" style="width: ${percent}%"></div>
            </div>
            <div class="chapter-score">${score.correct}/${score.total} (${percent}%)</div>
          </div>
        </div>
      `;
    });
    document.getElementById("chapter-results-list").innerHTML = chapterResultsHtml;

    // Generate feedback
    let feedbackText = "";
    if (overallPercent >= 80) {
      feedbackText = "🌟 Excellent performance! You have a strong understanding of the material. Keep up the great work!";
    } else if (overallPercent >= 60) {
      feedbackText = "👍 Good job! You have a decent understanding. Review the chapters where you scored lower to improve.";
    } else if (overallPercent >= 40) {
      feedbackText = "📚 You need to review the material more carefully. Focus on the chapters with lower scores.";
    } else {
      feedbackText = "⚠️ Please review all chapters thoroughly and retake the quiz to improve your scores.";
    }
    document.getElementById("feedback-text").textContent = feedbackText;

    // Show dashboard, hide quiz
    document.getElementById("quiz-section").style.display = "none";
    document.getElementById("dashboard-section").classList.add("active");
  }

  // Restart Quiz
  function restartQuiz() {
    currentSection = 0;
    chapterScores = {};
    document.getElementById("quiz-section").style.display = "block";
    document.getElementById("dashboard-section").classList.remove("active");
    loadSection();
  }

  // Download Results
  function downloadResults() {
    let totalCorrect = 0;
    let totalQuestions = 0;

    Object.keys(chapterScores).forEach(chapter => {
      const score = chapterScores[chapter];
      totalCorrect += score.correct;
      totalQuestions += score.total;
    });

    const overallPercent = ((totalCorrect / totalQuestions) * 100).toFixed(1);

    let csvContent = "data:text/csv;charset=utf-8,";
    csvContent += "Chapter,Correct,Total,Percentage\n";

    sectionNames.forEach(chapter => {
      const score = chapterScores[chapter];
      const percent = ((score.correct / score.total) * 100).toFixed(1);
      csvContent += `"${chapter}",${score.correct},${score.total},${percent}%\n`;
    });

    csvContent += `\nOverall,${totalCorrect},${totalQuestions},${overallPercent}%`;

    const encodedUri = encodeURI(csvContent);
    const link = document.createElement("a");
    link.setAttribute("href", encodedUri);
    link.setAttribute("download", "quiz_results.csv");
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }
</script>

</body>
</html>
